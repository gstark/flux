{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "convex": {
      "type": "local",
      "command": ["bunx", "convex", "mcp", "start"]
    },
    "daisyui-blueprint": {
      "type": "local",
      "command": [ "bunx", "daisyui-blueprint@latest"],
      "environment": {
        "LICENSE": "{env:DAISYUI_BLUEPRINT_LICENSE}",
        "EMAIL": "{env:DAISYUI_BLUEPRINT_EMAIL}"
      }
    }
  }
}
